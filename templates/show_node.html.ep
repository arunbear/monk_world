<%= $node->{title} %> <%= $node->{author_username} %>
  % if ($node->{reply} && ref $node->{reply} eq 'HASH') {
    <ul>
      % for my $id (sort { $b <=> $a } keys $node->{reply}->%*) {
        <li>
            %= include 'show_node', node=> $node->{reply}{$id}
        </li>
      % }
    </ul>
  % }