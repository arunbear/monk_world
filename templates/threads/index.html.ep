% layout 'default';
% title 'Threads';

<div class="container">
  <h1>Recent Threads</h1>
  % for my $section (sort keys %$threaded) {
    <h2><%= $section %></h2>
    <ul>
      % for my $node_id (sort { $b <=> $a } keys $threaded->{$section}->%*) {
        <li>
            %= include 'show_node', id=> $node_id, node=> $threaded->{$section}{$node_id}
        </li>
      % }
    </ul>
  % }
</div>
